{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Tenant namespace request",
  "type": "object",
  "required": ["namespace"],
  "additionalProperties": false,
  "properties": {
    "namespace": {
      "type": "object",
      "required": ["name", "env", "owner", "requestedBy", "purpose"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
        },
        "env": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["dev", "prod"]
          }
        },
        "owner": {
          "type": "string",
          "minLength": 1
        },
        "requestedBy": {
          "type": "string",
          "minLength": 1
        },
        "labels": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$"
          },
          "default": []
        },
        "policies": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "podSecurity": {
              "type": "string",
              "enum": ["baseline", "restricted"]
            }
          }
        },
        "purpose": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}